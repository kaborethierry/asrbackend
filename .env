# ============================================
# AGENCE SAINTE RITA VOYAGES - BACKEND
# VARIABLES D'ENVIRONNEMENT
# ============================================

# ----------------------
# SERVEUR
# ----------------------
PORT=5000
NODE_ENV=development

# ----------------------
# BASE DE DONNÉES
# ----------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=asr_voyages

# ----------------------
# JWT (Authentification)
# ----------------------
JWT_SECRET=asr-voyages-secret-key-2026-change-this-in-production
JWT_EXPIRE=7d

# ----------------------
# EMAIL (Nodemailer - Gmail)
# ----------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=asritavoyages@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_SECURE=false

# ----------------------
# FRONTEND URL (CORS)
# ----------------------
FRONTEND_URL=http://localhost:3000

# ----------------------
# UPLOAD
# ----------------------
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880