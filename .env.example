# .env.example - Copier vers .env

# Serveur
PORT=5000
NODE_ENV=development

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=asr_voyages

# JWT
JWT_SECRET=asr-voyages-secret-key-2026
JWT_EXPIRE=7d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=asritavoyages@gmail.com
SMTP_PASS=your_app_password
SMTP_SECURE=false

# Frontend
FRONTEND_URL=http://localhost:3000

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880